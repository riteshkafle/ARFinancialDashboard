    {
      "parameters": {
        "jsCode": "// Rolls up the whole sheet into the finance dashboard KPIs.\nconst items = $input.all()[0].json.data ?? $input.all().map((i) => i.json);\n\nconst paid = items.filter((i) => i.Status === 'Paid');\nconst pending = items.filter((i) => i.Status === 'Pending');\nconst overdue = items.filter((i) => i.Status === 'Overdue');\nconst highRisk = overdue.filter((i) => ['High', 'Escalate'].includes(i['Risk Score']));\n\nconst sum = (arr) => arr.reduce((t, i) => t + Number(i.Amount || 0), 0);\n\nconst totalPaid = sum(paid);\nconst totalOutstanding = sum(pending) + sum(overdue);\nconst totalARBalance = totalPaid + totalOutstanding;\nconst avgDaysLate = overdue.length\n  ? overdue.reduce((t, i) => t + Number(i['Days Late'] || 0), 0) / overdue.length\n  : 0;\n\nreturn [{\n  json: {\n    'Report Date': new Date().toISOString().slice(0, 10),\n    'Total Outstanding': totalOutstanding.toFixed(2),\n    'Total Paid': totalPaid.toFixed(2),\n    'Overdue Invoices': overdue.length,\n    'High Risk Accounts': highRisk.length,\n    'Average Days Late': avgDaysLate.toFixed(1),\n    'Total AR Balance': totalARBalance.toFixed(2),\n  },\n}];"
      },
