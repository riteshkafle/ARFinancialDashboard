    {
      "parameters": {
        "jsCode": "// Calculates days overdue and assigns a risk tier for every unpaid invoice.\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  const data = item.json;\n  const dueDate = new Date(data['Due Date']);\n  const diffMs = today - dueDate;\n  const daysLate = Math.max(0, Math.floor(diffMs / (1000 * 60 * 60 * 24)));\n\n  let riskLevel = 'None';\n  if (daysLate >= 30) riskLevel = 'Escalate';\n  else if (daysLate >= 16) riskLevel = 'High';\n  else if (daysLate >= 6) riskLevel = 'Medium';\n  else if (daysLate >= 1) riskLevel = 'Low';\n\n  let reminderStage = 'No';\n  if (riskLevel === 'Low') reminderStage = '1st Reminder';\n  else if (riskLevel === 'Medium') reminderStage = '2nd Reminder';\n  else if (riskLevel === 'High') reminderStage = '2nd Reminder';\n  else if (riskLevel === 'Escalate') reminderStage = 'Final Notice';\n\n  results.push({\n    json: {\n      ...data,\n      'Days Late': daysLate,\n      'Risk Score': riskLevel,\n      'Reminder Stage': reminderStage,\n      isOverdue: daysLate > 0,\n    },\n  });\n}\n\nreturn results;"
      },
      "id": "a1111111-0000-4000-8000-000000000004",
      "name": "Calculate Days Overdue & Risk",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-460, 180]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "b1111111-0000-4000-8000-000000000002",
              "leftValue": "={{ $json.isOverdue }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1111111-0000-4000-8000-000000000005",
      "name": "Filter Overdue Only",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.2,
      "position": [-220, 180]
    },
    {
      "parameters": {
        "jsCode": "// Assembles a risk-aware prompt for the AI model so tone escalates with days overdue.\nconst toneByRisk = {\n  Low: 'a warm, low-pressure first reminder that assumes this may just be an oversight',\n  Medium: 'a polite but noticeably firmer second reminder that references the earlier notice and asks for a status update',\n  High: 'a firm, professional notice that clearly states the account is significantly overdue and requests immediate payment or contact',\n  Escalate: 'a final notice that is direct and professional, references prior reminders, and mentions that continued non-payment may result in account hold or referral to collections',\n};\n\nreturn $input.all().map((item) => {\n  const d = item.json;\n  const tone = toneByRisk[d['Risk Score']] || toneByRisk.Low;\n\n  const prompt = `You are an Accounts Receivable specialist writing on behalf of AR Copilot Inc.\n\nWrite ${tone}.\n\nInvoice details:\n- Customer: ${d['Customer']}\n- Invoice ID: ${d['Invoice ID']}\n- Amount Due: $${Number(d['Amount']).toFixed(2)}\n- Original Due Date: ${d['Due Date']}\n- Days Overdue: ${d['Days Late']}\n- Risk Level: ${d['Risk Score']}\n\nRules:\n- Keep it under 150 words.\n- Sign off as \"AR Copilot Finance Team\".\n- Never sound threatening, even in the Escalate tier — stay professional and solution-oriented.\n- Return STRICT JSON only, no markdown, in this exact shape: {\"subject\": \"...\", \"body\": \"...\"}`;\n\n  return { json: { ...d, aiPrompt: prompt } };\n});"
      },
      "id": "a1111111-0000-4000-8000-000000000006",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [20, 180]
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You write concise, professional accounts-receivable reminder emails and return strict JSON only."
            },
            {
              "role": "user",
              "content": "={{ $json.aiPrompt }}"
            }
          ]
        },
        "jsonOutput": true,
        "options": {
          "temperature": 0.4
        }
      },
      "id": "a1111111-0000-4000-8000-000000000007",
      "name": "Generate Reminder Email (AI)",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.8,
      "position": [260, 180],
      "credentials": {
        "openAiApi": {
          "id": "PLACEHOLDER",
          "name": "OpenAI - AR Copilot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Safely parses the AI response into subject/body fields with a graceful fallback.\nreturn $input.all().map((item) => {\n  const raw = item.json.message?.content ?? item.json.content ?? item.json.text ?? '{}';\n  let parsed;\n  try {\n    parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n  } catch (e) {\n    parsed = {\n      subject: `Payment Reminder - Invoice ${item.json['Invoice ID']}`,\n      body: typeof raw === 'string' ? raw : 'Please contact our finance team regarding your outstanding invoice.',\n    };\n  }\n  return { json: { ...item.json, emailSubject: parsed.subject, emailBody: parsed.body } };\n});"
      },
